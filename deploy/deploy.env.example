# Copy this file on cPanel to:
# /home/tbkd2629/kost-simple-laravel/deploy/deploy.env
# Never commit the real deploy.env.

APP_PATH=/home/tbkd2629/kost-simple-laravel
PUBLIC_PATH=/home/tbkd2629/public_html
BRANCH=main

# Use HTTPS repo URL. For private repos, include a least-privilege token in the URL
# or configure cPanel Git credentials/deploy key if your host supports it.
# Example public repo: https://github.com/yodhasu/kost-simple-laravel.git
REPO_URL=

# Optional: set to 1 only when you explicitly want production migrations.
RUN_MIGRATIONS=0

# Optional binary overrides if cPanel paths are unusual.
PHP_BIN=php
COMPOSER_BIN=composer
GIT_BIN=git
